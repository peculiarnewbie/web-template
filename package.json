{
  "name": "web-template",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "vp exec alchemy deploy",
    "destroy": "vp exec alchemy destroy",
    "plan": "vp exec alchemy plan",
    "dev": "vp exec alchemy dev",
    "db:migrate": "wrangler d1 migrations apply web-template --remote",
    "db:generate": "drizzle-kit generate",
    "fmt": "vp fmt",
    "lint": "vp lint",
    "check": "vp check",
    "test": "vp test",
    "typecheck": "tsgo --noEmit",
    "styles": "npx tokenami --output ./src/styles.css",
    "styles:watch": "npx tokenami --output ./src/styles.css --watch"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.38.0",
    "@effect/platform-bun": "4.0.0-beta.84",
    "@effect/platform-node": "4.0.0-beta.84",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@tokenami/css": "^0.0.97",
    "alchemy": "2.0.0-beta.56",
    "drizzle-orm": "^1.0.0-rc.3",
    "effect": "4.0.0-beta.84",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260523.1",
    "@effect/vitest": "4.0.0-beta.84",
    "@tokenami/unplugin": "^0.0.97",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "drizzle-kit": "^1.0.0-rc.3",
    "jsdom": "^29.1.1",
    "tokenami": "^0.0.97",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.22",
    "vite-plugin-solid": "^2.11.12",
    "vite-plus": "^0.1.22",
    "vitest": "^4.1.7",
    "wrangler": "^4.83.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
